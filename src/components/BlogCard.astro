---
import LinkIcon from "./icons/LinkIcon.astro";

interface Props {
	url: string;
	title: string;
	date: string;
}

const props = Astro.props;
---

<a
	href={props.url}
	class="border-border/50 border w-full group hover:cursor-pointer grid grid-cols-[1fr,auto] justify-start items-center gap-1 grid-rows-[auto,auto] shadow-inner-card bg-background/10 p-5 rounded-2xl">
	<p
		class="col-[2/3] row-[1/2] w-full capitalize line-clamp-1 text-base group-hover:text-link ease-in-out transition-colors duration-300">
		{props.title}
	</p>
	<p class="row-[2/3] col-[1/3] text-sm text-muted">{props.date}</p>
	<LinkIcon
		aria-hidden
		className="text-body mr-1 row-[1/2] col-[1/2] size-4 group-hover:text-link ease-in-out transition-colors duration-300"
	/>
</a>
