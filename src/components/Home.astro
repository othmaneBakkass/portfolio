---
import { Image } from "astro:assets";
import Navbar from "@/components/Navbar.astro";
import Introduction from "@/components/Introduction.astro";
import TechStack from "@/components/TechStack.astro";
import Projects from "@/components/Projects.astro";
import Writings from "@/components/Writings.astro";
import Footer from "./Footer.astro";

import topFog from "@/lib/images/fog_top.svg";
import bottomFog from "@/lib/images/fog_bottom.svg";
---

<>
	<Navbar data-animate-entry style="--i:0" />
	<Introduction data-animate-entry style="--i:1" />
	<TechStack data-animate-entry style="--i:2" />
	<Projects data-animate-entry style="--i:3" />
	<Writings data-animate-entry style="--i:4" />
	<Footer data-animate-entry style="--i:5" />
	<Image
		class={"absolute top-0 left-0 -z-20"}
		src={topFog}
		aria-hidden
		alt={"a blueish fog"}
		width={"550"}
	/>
	<Image
		class={"absolute bottom-0 right-0 -z-20"}
		src={bottomFog}
		aria-hidden
		alt={"a blueish fog"}
		width={"550"}
	/>
</>
